@model EcommerceManagement.Web.Dtos.Users.Commands.CheckEmailModalDto

@{
    ViewData["Title"] = "Check Email";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="hero">
    <div class="container">
        <div class="row justify-content-between">
            <div class="col-lg-5">
                <div class="intro-excerpt">
                    <h1>Find your account</h1>
                </div>
            </div>
            <div class="col-lg-7">
            </div>
        </div>
    </div>
</div>

<div class="container-fluid py-5">
    <div class="container py-5">
        <div class="row mb-5">
            <div class="col-lg-8 offset-lg-2">
                <form id="resetOptionsForm" asp-action="ForgetPassword" method="post">
                    <div class="text-danger" asp-validation-summary="All"></div>
                    <div class="row">
                        <div class="p-3 p-lg-5 border bg-white">
                            <h2 class="h3 mb-4 text-black">How would you like to receive a code to reset your password?</h2>
                            <ul class="list-group mt-3">
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <a href="#" data-bs-toggle="modal" data-bs-target="#googleModal">
                                        <input type="radio" name="resetOption" class="me-2"> Use my Google account<br />
                                        Sign in to Google (if you're not already signed in) to quickly reset your password.
                                    </a>
                                </li>
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <a href="#" data-bs-toggle="modal" data-bs-target="#emailCheckModal">
                                        <input type="radio" name="resetOption" class="me-2"> Send code via email
                                    </a>
                                </li>
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <a href="#" data-bs-toggle="modal" data-bs-target="#facebookModal">
                                        <input type="radio" name="resetOption" class="me-2"> Send code via Facebook notification <br />
                                        You're signed in on another app or device. Please receive a notification with your login code.
                                    </a>
                                </li>
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <a href="#" data-bs-toggle="modal" data-bs-target="#smsModal">
                                        <input type="radio" name="resetOption" class="me-2"> Send code via SMS
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Email Check Modal -->
<div class="modal fade" id="emailCheckModal" tabindex="-1" aria-labelledby="emailCheckModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="emailCheckModalLabel">Check Email</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="emailCheckForm" asp-action="CheckEmail" method="post">
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email Address</label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Next</button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .list-group-item a {
        text-decoration: none;
    }

    .list-group-item {
        border: none;
    }
</style>
