@model EcommerceManagement.Web.Dtos.Users.Commands.ForgetPasswordModalDto

@{
    ViewData["Title"] = "Forget Password";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="hero">
    <div class="container">
        <div class="row justify-content-between">
            <div class="col-lg-5">
                <div class="intro-excerpt">
                    <h1>Reset Password</h1>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container py-5">
    <div class="row mb-5">
        <div class="col-lg-6 offset-lg-3">
            <div class="alert alert-info text-center">
                Remember your password? <a asp-action="Login" asp-controller="User">Click here</a> to login.
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-6 offset-lg-3">
            <div class="card p-4">
                <form asp-action="ForgetPassword" method="post">
                    <div class="form-group mb-3">
                        <input type="hidden" asp-for="Email" />
                    </div>

                    <div class="form-group mb-3">
                        <input asp-for="Password" class="form-control" type="password" placeholder="Enter new password" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-4">
                        <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Confirm new password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <div class="form-group my-5">
                        <button type="submit" class="btn btn-primary btn-lg btn-block">Reset Password</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
