@model EcommerceManagement.Web.Dtos.Users.Commands.UserLoginModalDto

@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="hero">
    <div class="container">
        <div class="row justify-content-between">
            <div class="col-lg-5">
                <div class="intro-excerpt">
                    <h1>Login</h1>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container py-5">
    <div class="row mb-5">
        <div class="col-lg-6 offset-lg-3">
            <div class="alert alert-info text-center">
                New customer? <a asp-action="Register" asp-controller="User">Click here</a> to register.
            </div>
            @if (TempData["Message"] != null)
            {
                <div class="alert alert-info">
                    @TempData["Message"]
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger text-center">
                    @TempData["ErrorMessage"]
                </div>
            }
        </div>
    </div>

    <div class="row">
        <div class="col-lg-6 offset-lg-3">
            <div class="card p-4">
                <form asp-action="Login" asp-controller="User" method="post">
                    <div class="form-group mb-4">
                        <input asp-for="UserName" type="text" class="form-control" placeholder="Enter your username" />
                        <span asp-validation-for="UserName" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-4">
                        <input asp-for="Password" class="form-control" placeholder="Enter your password" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="form-group d-flex justify-content-between align-items-center">
                        <button class="btn btn-primary btn-lg" type="submit">Login</button>
                        <a asp-controller="User" asp-action="CheckEmail" class="btn btn-link" style="text-decoration: none;">Forgot Password?</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
